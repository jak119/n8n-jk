{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "dockerfile": {
    "enabled": true
  },
  "docker": {
    "enabled": true
  },
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "automerge": false,
  "major": {
    "enabled": true
  },
  "minor": {
    "enabled": true
  },
  "patch": {
    "enabled": true
  }
}