{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
"config:recommended"
  ],
  "dockerfile": {
    "enabled": true
  },
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "automerge": false,
  "major": {
    "enabled": true
  },
  "minor": {
    "enabled": true
  },
  "patch": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchCategories": ["docker"],
      "enabled": true
    }
  ]
}
